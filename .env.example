# Database (Docker PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/envmanager"

# Encryption - must be exactly 64 hex characters (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-hex-char-string-here-replace-this-before-running"

# JWT - use a long random string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET="your-jwt-secret-here-replace-this-before-running"

# Hono API port
PORT=3001

# Anthropic API (for AI Security Scanner)
ANTHROPIC_API_KEY="sk-ant-your-key-here"
