{
  "name": "@envmanager/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm with-env node --watch --import tsx/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "with-env": "dotenv -e .env --",
    "db:generate": "pnpm with-env prisma generate",
    "db:migrate": "pnpm with-env prisma migrate dev",
    "db:studio": "pnpm with-env prisma studio"
  },
  "dependencies": {
    "@envmanager/types": "workspace:*",
    "@hono/node-server": "^2.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.19",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  }
}
